
{
  "name": "zakolcovo-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot server for Zakolcovo restaurant",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node -r dotenv/config dist/bot.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/bot.ts"
  },
  "keywords": [
    "telegram",
    "bot",
    "gemini",
    "nodejs"
  ],
  "author": "AI Assistant",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^0.12.0",
    "dotenv": "^16.4.5",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/node-telegram-bot-api": "^0.64.6",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
